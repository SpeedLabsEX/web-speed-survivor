# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets)
# .env / .env.local hold server-only secrets and stay gitignored.
# .env.production is tracked because it ONLY holds NEXT_PUBLIC_* values that
# Next inlines into the client bundle anyway — there's no secrecy gain from
# hiding them, and tracking them keeps prod builds reproducible from CI.
.env*
!.env.example
!.env.local.example
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo

# IDE
.vscode/
.idea/
