# =====================================================================
# Public env vars (safe to ship to the browser)
# =====================================================================

# api-speed-survivor base URL.
# Production: https://speed-survivor-api-3xewp.ondigitalocean.app
# Local dev:  http://localhost:8000 (or wherever your local API runs)
NEXT_PUBLIC_API_BASE_URL=https://speed-survivor-api-3xewp.ondigitalocean.app

# Where this web app is hosted (used for Coinflow return URLs)
NEXT_PUBLIC_APP_URL=http://localhost:8081

# Firebase web SDK config — same project as the mobile app (speed-labs-198e6)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDP4q2W66YcUURmyZA3dYW3E1BZ7ISjLmk
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=speed-labs-198e6.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=speed-labs-198e6
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=speed-labs-198e6.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=347026101112
NEXT_PUBLIC_FIREBASE_APP_ID=1:347026101112:web:050f2b31ac282d3362ae8d
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-5GZSRPKVV5

# Coinflow client config — sandbox or prod
NEXT_PUBLIC_COINFLOW_ENV=sandbox
NEXT_PUBLIC_COINFLOW_MERCHANT_ID=speedsurvivor

# Feature flags
NEXT_PUBLIC_ENABLE_TEST_1_CENT=true
NEXT_PUBLIC_FEATURE_WITHDRAWALS=true

# Provider-agnostic payments API. Keep NEXT_PUBLIC_API_BASE_URL on
# api-speed-survivor for auth, balance, and transaction-history reads.
PAYMENTS_API_BASE_URL=http://127.0.0.1:8080

# =====================================================================
# Server-only env vars (NEVER prefix with NEXT_PUBLIC_)
# =====================================================================

# JWT issued by api-speed-survivor on /api/v1/auth/login. We do not need to
# verify it locally (the API does that on every request); we just store it
# in an httpOnly cookie and forward it. The shared secret is OPTIONAL and
# only needed if you want to read claims server-side without a network hop.
APP_JWT_SHARED_SECRET=
